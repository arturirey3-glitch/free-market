---
import { formatJPY } from '../lib/format';

interface Props {
  product: {
    id: string;
    title: string;
    price: number;
    thumbnail_url: string | null;
    review_count?: number;
    review_average?: number;
    profiles?: { display_name: string | null; avatar_url: string | null };
  };
}

const { product } = Astro.props;
const shortId = product.id.slice(0, 8);
---
<a href={`/products/${shortId}`} class="card block group">
  <div class="relative aspect-square w-full overflow-hidden bg-[var(--bg-secondary)]">
    {product.thumbnail_url ? (
      <img
        src={product.thumbnail_url}
        alt={product.title}
        class="h-full w-full object-cover transition duration-300 group-hover:scale-105"
        loading="lazy"
      />
    ) : (
      <div class="flex h-full w-full items-center justify-center text-sm text-[var(--text-placeholder)]">
        No Image
      </div>
    )}
    <div class="absolute bottom-0 left-0 bg-black/60 text-white text-xs font-bold px-2 py-1">
      {formatJPY(product.price)}
    </div>
  </div>
  <div class="px-2 py-2">
    <h3 class="text-xs leading-snug line-clamp-2">{product.title}</h3>
    {(product.review_count ?? 0) > 0 && (
      <div class="mt-1 flex items-center gap-0.5 text-[10px] text-[var(--text-secondary)]">
        <span class="text-[var(--star)]">★</span>
        <span>{(product.review_average ?? 0).toFixed(1)}</span>
        <span>({product.review_count})</span>
      </div>
    )}
  </div>
</a>
