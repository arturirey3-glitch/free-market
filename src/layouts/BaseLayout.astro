---
import globalStyles from '../styles/global.css?url';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogUrl?: string;
  ogType?: string;
  jsonLd?: string;
}

const { title = 'felikko | フリマサイト', description, ogImage, ogUrl, ogType = 'website', jsonLd } = Astro.props;
const siteUrl = 'https://www.felikko.com';
const canonicalUrl = ogUrl || siteUrl + Astro.url.pathname;
const GA_ID = import.meta.env.GA_MEASUREMENT_ID || '';
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="stylesheet" href={globalStyles} />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <meta property="og:title" content={title} />
    <meta property="og:site_name" content="felikko" />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    {description && <meta property="og:description" content={description} />}
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && <meta property="og:image:width" content="1200" />}
    {ogImage && <meta property="og:image:height" content="630" />}
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    <!-- Google Analytics 4 -->
    {GA_ID && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
        <script define:vars={{ GA_ID }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', GA_ID);
        </script>
      </>
    )}
    {jsonLd && <Fragment set:html={`<script type="application/ld+json">${jsonLd}</script>`} />}
    <slot name="head" />
  </head>
  <body>
    <div class="min-h-screen flex flex-col">
      <!-- Header -->
      <header class="sticky top-0 z-40 bg-white border-b border-[var(--border-light)]">
        <div class="mx-auto flex max-w-[1440px] items-center justify-between px-4 h-16">
          <a href="/" class="shrink-0">
            <img src="/felikko-logo.png" alt="felikko" class="h-11 w-auto" />
          </a>

          <!-- Search -->
          <div class="hidden sm:flex flex-1 max-w-md mx-6">
            <form action="/products" method="get" class="flex w-full">
              <input
                type="text"
                name="q"
                placeholder="なにをお探しですか？"
                class="flex-1 rounded-l-full border border-r-0 border-[var(--border)] px-4 py-2 text-sm outline-none focus:border-[var(--primary)]"
              />
              <button type="submit" class="rounded-r-full bg-[var(--primary)] px-4 text-white text-sm font-bold">
                検索
              </button>
            </form>
          </div>

          <nav class="flex items-center gap-4 text-sm font-medium">
            <a href="/products" class="hidden md:block hover:text-[var(--primary)]">商品一覧</a>
            <a href="/dashboard" class="hidden md:block hover:text-[var(--primary)]">マイページ</a>
            <a href="/auth/login" class="hover:text-[var(--primary)]" data-auth-login>ログイン</a>
            <button type="button" class="hidden hover:text-[var(--primary)]" data-auth-logout>ログアウト</button>
            <a href="/dashboard/products/new" class="btn-primary">出品</a>
          </nav>
        </div>
        <!-- Mobile search -->
        <div class="sm:hidden px-4 pb-3">
          <form action="/products" method="get" class="flex">
            <input
              type="text"
              name="q"
              placeholder="なにをお探しですか？"
              class="flex-1 rounded-l-full border border-r-0 border-[var(--border)] px-4 py-2 text-sm outline-none"
            />
            <button type="submit" class="rounded-r-full bg-[var(--primary)] px-4 text-white text-sm font-bold">
              検索
            </button>
          </form>
        </div>
      </header>

      <!-- Main -->
      <main class="flex-1">
        <slot />
      </main>

      <!-- Footer -->
      <footer class="border-t border-[var(--border-light)] bg-[var(--bg-secondary)] py-8">
        <div class="mx-auto max-w-[1440px] px-4 text-xs text-[var(--text-secondary)]">
          <ul class="flex flex-wrap gap-4 mb-4">
            <li><a href="/privacy" class="hover:text-[var(--text-primary)]">プライバシーポリシー</a></li>
            <li><a href="/law" class="hover:text-[var(--text-primary)]">特定商取引法に基づく表記</a></li>
          </ul>
          <p>&copy; 2026 <a href="https://www.felikko.com" class="hover:text-[var(--text-primary)]">felikko</a></p>
        </div>
      </footer>
    </div>

    <script>
    import { supabase } from '../lib/supabaseClient';

    const loginLinks = document.querySelectorAll('[data-auth-login]');
    const logoutButtons = document.querySelectorAll('[data-auth-logout]');

    const setAuthUI = (isLoggedIn: boolean) => {
      loginLinks.forEach((el) => el.classList.toggle('hidden', isLoggedIn));
      logoutButtons.forEach((el) => el.classList.toggle('hidden', !isLoggedIn));
    };

    const { data } = await supabase.auth.getSession();
    setAuthUI(!!data.session);

    logoutButtons.forEach((btn) => {
      btn.addEventListener('click', async () => {
        await supabase.auth.signOut();
        setAuthUI(false);
        window.location.href = '/';
      });
    });

    supabase.auth.onAuthStateChange((_event, session) => setAuthUI(!!session));
    </script>
  </body>
</html>
