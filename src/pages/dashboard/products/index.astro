---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Toast from '../../../components/Toast.astro';
---
<BaseLayout title="出品した商品 | felikko">
  <Toast />
  <div class="mx-auto max-w-[960px] px-4 py-6">
    <div class="flex items-center justify-between mb-6">
      <h1 class="text-lg font-bold">出品した商品</h1>
      <a href="/dashboard/products/new" class="btn-primary text-sm py-2 px-4">＋ 新規出品</a>
    </div>

    <!-- 並び替えヒント -->
    <p id="sort-hint" class="hidden mb-3 text-xs text-[var(--text-secondary)]">
      ⠿ をドラッグして並び替えできます。順番は自動で保存されます。
    </p>

    <div id="products-list">
      <p class="text-sm text-[var(--text-secondary)]">読み込み中...</p>
    </div>
  </div>

  <!-- SortableJS CDN -->
  <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.6/Sortable.min.js"></script>

  <script>
  import { supabase } from '../../../lib/supabaseClient';

  declare global {
    interface Window {
      showToast: (type: 'success' | 'error' | 'info', title: string, message: string) => void;
      Sortable: any;
    }
  }

  const container = document.getElementById('products-list')!;
  const hint = document.getElementById('sort-hint')!;

  const { data: sessionData } = await supabase.auth.getSession();
  if (!sessionData.session) { window.location.href = '/auth/login'; }

  const { data, error } = await supabase
    .from('products')
    .select('id,title,price,status,thumbnail_url,created_at,sort_order,is_pickup')
    .eq('owner_id', sessionData.session!.user.id)
    .order('sort_order', { ascending: true, nullsFirst: false })
    .order('created_at', { ascending: false });

  if (error || !data || data.length === 0) {
    container.innerHTML = `
      <div class="flex flex-col items-center justify-center py-16 text-center">
        <p class="text-sm text-[var(--text-secondary)]">出品した商品はまだありません</p>
        <a href="/dashboard/products/new" class="btn-primary mt-4 text-sm py-2 px-5">最初の商品を出品する</a>
      </div>
    `;
  } else {
    hint.classList.remove('hidden');

    container.innerHTML = `
      <div id="sortable-list" class="space-y-2">
        ${data.map((p: any, i: number) => `
          <div class="card flex items-center gap-3 p-3 cursor-default" data-id="${p.id}">
            <!-- ドラッグハンドル -->
            <div class="drag-handle cursor-grab active:cursor-grabbing text-[var(--text-placeholder)] select-none px-1 shrink-0 text-lg" title="ドラッグして並び替え">⠿</div>
            <!-- 順番 -->
            <span class="item-order shrink-0 w-6 text-center text-xs font-bold text-[var(--text-secondary)]">${i + 1}</span>
            <!-- サムネイル -->
            <div class="h-14 w-14 shrink-0 rounded-lg bg-[var(--bg-secondary)] overflow-hidden">
              ${p.thumbnail_url
                ? `<img src="${p.thumbnail_url}" class="h-full w-full object-cover" />`
                : '<div class="h-full w-full flex items-center justify-center text-[var(--text-placeholder)] text-xl">📷</div>'}
            </div>
            <!-- 商品情報 -->
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium truncate">${p.title}</p>
              <span class="inline-block mt-0.5 rounded px-1.5 py-0.5 text-[10px] font-medium ${p.status === 'published' ? 'bg-[var(--primary-light)] text-[var(--primary)]' : 'bg-[var(--bg-secondary)] text-[var(--text-secondary)]'}">
                ${p.status === 'published' ? '公開中' : '下書き'}
              </span>
            </div>
            <p class="text-sm font-bold shrink-0">¥${Number(p.price).toLocaleString()}</p>
            <div class="flex gap-2 shrink-0">
              <button class="pickup-btn shrink-0 rounded border px-2 py-1 text-xs font-medium transition ${p.is_pickup ? 'border-amber-400 bg-amber-50 text-amber-600' : 'border-[var(--border)] text-[var(--text-secondary)] hover:border-amber-400 hover:text-amber-500'}" data-id="${p.id}" data-pickup="${p.is_pickup ? '1' : '0'}">${p.is_pickup ? '⭐ 固定中' : '☆ 固定'}</button>
              <a href="/dashboard/products/${p.id}" class="btn-outline text-xs py-1 px-2">編集</a>
              <button class="btn-danger text-xs py-1 px-2" data-delete="${p.id}">削除</button>
            </div>
          </div>
        `).join('')}
      </div>
    `;

    // 順番表示を更新する関数
    function updateOrderNumbers() {
      const items = document.querySelectorAll<HTMLElement>('#sortable-list [data-id]');
      items.forEach((el, i) => {
        const orderEl = el.querySelector('.item-order');
        if (orderEl) orderEl.textContent = String(i + 1);
      });
    }

    // Supabase に sort_order を一括保存する関数
    async function saveSortOrder() {
      const items = document.querySelectorAll<HTMLElement>('#sortable-list [data-id]');
      const updates = Array.from(items).map((el, i) => ({
        id: el.dataset.id!,
        sort_order: i + 1,
      }));

      // 各アイテムを個別に update（Supabase REST は upsert で一括可）
      const promises = updates.map(({ id, sort_order }) =>
        supabase.from('products').update({ sort_order }).eq('id', id)
      );
      const results = await Promise.all(promises);
      const failed = results.filter(r => r.error);
      if (failed.length > 0) {
        window.showToast?.('error', '保存失敗', '並び替えの保存に失敗しました');
      } else {
        window.showToast?.('success', '保存しました', '並び順を更新しました');
      }
    }

    // SortableJS 初期化（CDN が読み込まれてから）
    function initSortable() {
      const list = document.getElementById('sortable-list');
      if (!list || !window.Sortable) return;

      window.Sortable.create(list, {
        handle: '.drag-handle',
        animation: 150,
        ghostClass: 'opacity-40',
        onEnd: async () => {
          updateOrderNumbers();
          await saveSortOrder();
        },
      });
    }

    // CDN 読み込み待ち
    if (window.Sortable) {
      initSortable();
    } else {
      document.querySelector('script[src*="Sortable"]')?.addEventListener('load', initSortable);
      // fallback: poll
      let tries = 0;
      const poll = setInterval(() => {
        if (window.Sortable || ++tries > 20) { clearInterval(poll); initSortable(); }
      }, 100);
    }

    // ピックアップトグル
    container.querySelectorAll<HTMLButtonElement>('.pickup-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = btn.dataset.id!;
        const current = btn.dataset.pickup === '1';
        const next = !current;
        btn.disabled = true;
        const { error } = await supabase.from('products').update({ is_pickup: next }).eq('id', id);
        if (error) {
          window.showToast?.('error', 'エラー', error.message);
        } else {
          btn.dataset.pickup = next ? '1' : '0';
          btn.textContent = next ? '⭐ 固定中' : '☆ 固定';
          if (next) {
            btn.className = btn.className.replace('border-[var(--border)] text-[var(--text-secondary)] hover:border-amber-400 hover:text-amber-500', 'border-amber-400 bg-amber-50 text-amber-600');
          } else {
            btn.className = btn.className.replace('border-amber-400 bg-amber-50 text-amber-600', 'border-[var(--border)] text-[var(--text-secondary)] hover:border-amber-400 hover:text-amber-500');
          }
          window.showToast?.('success', next ? 'ピックアップに追加しました' : 'ピックアップを解除しました', '');
        }
        btn.disabled = false;
      });
    });

    // 削除ボタン
    container.querySelectorAll<HTMLButtonElement>('[data-delete]').forEach(btn => {
      btn.addEventListener('click', async () => {
        if (!confirm('この商品を削除してよいですか？')) return;
        const id = btn.dataset.delete!;
        btn.disabled = true;
        const { error } = await supabase.from('products').delete().eq('id', id);
        if (error) {
          window.showToast?.('error', 'エラー', error.message);
          btn.disabled = false;
        } else {
          btn.closest('[data-id]')?.remove();
          updateOrderNumbers();
          window.showToast?.('success', '削除しました', '');
          if (!container.querySelector('[data-id]')) {
            hint.classList.add('hidden');
            container.innerHTML = `<div class="flex flex-col items-center justify-center py-16 text-center"><p class="text-sm text-[var(--text-secondary)]">出品した商品はまだありません</p><a href="/dashboard/products/new" class="btn-primary mt-4 text-sm py-2 px-5">最初の商品を出品する</a></div>`;
          }
        }
      });
    });
  }
  </script>
</BaseLayout>
