---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatJPY, formatRelativeTime } from '../../lib/format';
import { createSupabaseServer } from '../../lib/supabaseServer';

export const prerender = false;

const { id } = Astro.params;
let product: any = null;
let galleryImages: any[] = [];
let reviews: any[] = [];
let averageRating = 0;
let ratingRounded = '0.0';

try {
  const supabase = createSupabaseServer();
  const isShort = id && id.length === 8;
  const fields = 'id,owner_id,title,description,price,category,thumbnail_url,is_subscription,delivery_time,purchase_notes,created_at,updated_at,profiles:owner_id(display_name,avatar_url,bio,is_verified,sales_count,rating,rating_count),product_images(id,image_url,sort_order)';

  if (isShort) {
    const { data } = await supabase.from('products').select(fields).eq('status', 'published');
    product = data?.find((p: any) => p.id.startsWith(id!)) ?? null;
  } else {
    const { data } = await supabase.from('products').select(fields).eq('id', id).eq('status', 'published').single();
    product = data;
  }

  if (product) {
    galleryImages = (product.product_images ?? []).sort((a: any, b: any) => (a.sort_order ?? 0) - (b.sort_order ?? 0));
    const { data: revData } = await supabase.from('reviews').select('*').eq('product_id', product.id).order('created_at', { ascending: false });
    reviews = revData ?? [];
    if (reviews.length > 0) {
      averageRating = reviews.reduce((s, r) => s + r.rating, 0) / reviews.length;
      ratingRounded = averageRating.toFixed(1);
    }
  }
} catch {}

if (!product) return Astro.redirect('/products');
const profile = product.profiles;
const allImages = galleryImages.length > 0
  ? galleryImages.map((img: any) => img.image_url)
  : product.thumbnail_url ? [product.thumbnail_url] : [];
---
<BaseLayout title={`${product.title} | Free Market`}>
  <div class="mx-auto max-w-[960px] px-4 py-6">
    <div class="md:flex md:gap-8">
      <!-- Images -->
      <div class="md:w-1/2">
        {allImages.length > 0 ? (
          <>
            <div class="aspect-square w-full overflow-hidden rounded-lg bg-[var(--bg-secondary)]">
              <img src={allImages[0]} alt={product.title} class="h-full w-full object-cover" id="main-image" />
            </div>
            {allImages.length > 1 && (
              <div class="mt-2 flex gap-2 overflow-x-auto">
                {allImages.map((src: string) => (
                  <button
                    class="h-16 w-16 shrink-0 overflow-hidden rounded border border-[var(--border-light)] hover:border-[var(--primary)]"
                    data-gallery-thumb={src}
                  >
                    <img src={src} alt="" class="h-full w-full object-cover" />
                  </button>
                ))}
              </div>
            )}
          </>
        ) : (
          <div class="flex aspect-square w-full items-center justify-center rounded-lg bg-[var(--bg-secondary)] text-[var(--text-placeholder)]">No Image</div>
        )}
      </div>

      <!-- Info -->
      <div class="mt-6 md:mt-0 md:w-1/2">
        <h1 class="text-lg font-bold leading-snug">{product.title}</h1>

        <div class="mt-2 flex items-center gap-2">
          <span class="text-2xl font-bold text-[var(--danger)]">{formatJPY(product.price)}</span>
          {product.is_subscription && <span class="rounded bg-[var(--primary-light)] px-2 py-0.5 text-[10px] font-bold text-[var(--primary)]">月額</span>}
        </div>

        {reviews.length > 0 && (
          <div class="mt-2 flex items-center gap-1 text-sm">
            <span class="text-[var(--star)]">★</span>
            <span class="font-bold">{ratingRounded}</span>
            <span class="text-[var(--text-secondary)]">({reviews.length}件)</span>
          </div>
        )}

        <div class="mt-4 flex gap-2">
          <button class="btn-primary flex-1 py-3 text-base" data-checkout data-product-id={product.id} data-title={product.title} data-price={product.price} data-mode={product.is_subscription ? 'subscription' : 'payment'}>
            {product.is_subscription ? '月額プランに申し込む' : '購入手続きへ'}
          </button>
        </div>

        {product.category && (
          <div class="mt-4">
            <span class="inline-block rounded-full border border-[var(--border)] px-3 py-1 text-xs">{product.category}</span>
          </div>
        )}

        {product.delivery_time && (
          <p class="mt-3 text-xs text-[var(--text-secondary)]">お届け日数: 約{product.delivery_time}日</p>
        )}

        <!-- Seller -->
        {profile && (
          <div class="mt-6 flex items-center gap-3 rounded-lg border border-[var(--border-light)] p-3">
            {profile.avatar_url ? (
              <img src={profile.avatar_url} alt="" class="h-10 w-10 rounded-full object-cover" />
            ) : (
              <div class="flex h-10 w-10 items-center justify-center rounded-full bg-[var(--bg-secondary)] text-xs text-[var(--text-placeholder)]">U</div>
            )}
            <div>
              <p class="text-sm font-bold">{profile.display_name ?? '出品者'}</p>
              {profile.rating && (
                <p class="text-xs text-[var(--text-secondary)]">★ {Number(profile.rating).toFixed(1)} ({profile.rating_count}件)</p>
              )}
            </div>
          </div>
        )}
      </div>
    </div>

    <!-- Description -->
    <section class="mt-8 border-t border-[var(--border-light)] pt-6">
      <h2 class="text-base font-bold mb-3">商品の説明</h2>
      <div class="text-sm leading-relaxed whitespace-pre-wrap">{product.description}</div>
    </section>

    {product.purchase_notes && (
      <section class="mt-6 border-t border-[var(--border-light)] pt-6">
        <h2 class="text-base font-bold mb-3">購入にあたって</h2>
        <div class="text-sm leading-relaxed whitespace-pre-wrap">{product.purchase_notes}</div>
      </section>
    )}

    <!-- Reviews -->
    <section class="mt-6 border-t border-[var(--border-light)] pt-6">
      <h2 class="text-base font-bold mb-4">
        レビュー
        {reviews.length > 0 && <span class="text-[var(--text-secondary)] font-normal">({reviews.length}件)</span>}
      </h2>
      {reviews.length > 0 ? (
        <div class="space-y-4">
          {reviews.map((review) => (
            <div class="rounded-lg border border-[var(--border-light)] p-4">
              <div class="flex items-center gap-2">
                {review.reviewer_avatar_url ? (
                  <img src={review.reviewer_avatar_url} alt="" class="h-8 w-8 rounded-full object-cover" />
                ) : (
                  <div class="flex h-8 w-8 items-center justify-center rounded-full bg-[var(--bg-secondary)] text-xs">U</div>
                )}
                <div>
                  <p class="text-xs font-bold">{review.reviewer_name ?? '購入者'}</p>
                  <div class="flex items-center gap-1">
                    <span class="text-xs text-[var(--star)]">{'★'.repeat(review.rating)}{'☆'.repeat(5 - review.rating)}</span>
                    <span class="text-[10px] text-[var(--text-placeholder)]">{formatRelativeTime(review.created_at)}</span>
                  </div>
                </div>
              </div>
              {review.title && <p class="mt-2 text-sm font-bold">{review.title}</p>}
              {review.body && <p class="mt-1 text-sm text-[var(--text-secondary)]">{review.body}</p>}
              {review.reply && (
                <div class="mt-3 rounded bg-[var(--bg-secondary)] p-3">
                  <p class="text-[10px] font-bold text-[var(--text-secondary)] mb-1">出品者からの返信</p>
                  <p class="text-sm">{review.reply}</p>
                </div>
              )}
            </div>
          ))}
        </div>
      ) : (
        <p class="text-sm text-[var(--text-secondary)]">まだレビューはありません</p>
      )}
    </section>
  </div>

  <script>
    // Gallery thumbnail click
    document.querySelectorAll<HTMLButtonElement>('[data-gallery-thumb]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const img = document.getElementById('main-image') as HTMLImageElement;
        if (img && btn.dataset.galleryThumb) img.src = btn.dataset.galleryThumb;
      });
    });

    // Checkout
    document.querySelectorAll<HTMLButtonElement>('[data-checkout]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        btn.disabled = true;
        btn.textContent = '処理中...';
        try {
          const res = await fetch('/api/checkout', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              productId: btn.dataset.productId,
              productTitle: btn.dataset.title,
              price: Number(btn.dataset.price),
              mode: btn.dataset.mode
            })
          });
          const data = await res.json();
          if (data.url) {
            window.location.href = data.url;
          } else {
            alert(data.error || 'エラーが発生しました');
            btn.disabled = false;
            btn.textContent = btn.dataset.mode === 'subscription' ? '月額プランに申し込む' : '購入手続きへ';
          }
        } catch {
          alert('エラーが発生しました');
          btn.disabled = false;
          btn.textContent = '購入手続きへ';
        }
      });
    });
  </script>
</BaseLayout>
