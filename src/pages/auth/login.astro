---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Toast from '../../components/Toast.astro';
---
<BaseLayout title="ログイン | Free Market">
  <Toast />
  <div class="mx-auto max-w-md px-4 py-12">
    <section class="rounded-lg border border-[var(--border-light)] bg-white p-8">
      <h1 class="text-xl font-bold">ログイン</h1>
      <p class="mt-2 text-xs text-[var(--text-secondary)]">登録済みのメールアドレスでログインしてください。</p>
      <form class="mt-6 space-y-4" data-auth-form data-mode="login" method="post" action="javascript:void(0)">
        <div>
          <label class="text-xs text-[var(--text-secondary)]">メールアドレス</label>
          <input type="email" name="email" required class="input-field mt-1" />
        </div>
        <div>
          <label class="text-xs text-[var(--text-secondary)]">パスワード</label>
          <input type="password" name="password" minlength="6" required class="input-field mt-1" />
        </div>
        <button type="submit" class="btn-primary w-full py-3 text-sm">ログイン</button>
        <button type="button" class="btn-outline w-full py-3 text-sm" data-auth-reset>パスワード再発行</button>
        <p class="text-center text-xs text-[var(--text-secondary)]">
          アカウントがない場合は <a href="/auth/signup" class="text-[var(--primary)] font-bold">新規登録</a>
        </p>
        <p class="text-center text-xs" data-auth-message></p>
      </form>
    </section>
  </div>
</BaseLayout>

<script>
import { supabase } from '../../lib/supabaseClient';

declare global { interface Window { showToast: (type: 'success' | 'error' | 'info', title: string, message: string) => void; } }

const form = document.querySelector<HTMLFormElement>('[data-auth-form]');
const resetButton = document.querySelector<HTMLButtonElement>('[data-auth-reset]');

const tr: Record<string, string> = {
  'Email not confirmed': 'メールアドレスが確認されていません。確認メールのリンクをクリックしてください。',
  'Invalid login credentials': 'メールアドレスまたはパスワードが正しくありません。',
};
const translateError = (msg: string) => { for (const [k, v] of Object.entries(tr)) { if (msg.includes(k)) return v; } return msg; };

form?.addEventListener('submit', async (e) => {
  e.preventDefault();
  const fd = new FormData(form);
  const email = `${fd.get('email') ?? ''}`.trim();
  const password = `${fd.get('password') ?? ''}`.trim();
  if (!email || !password) { window.showToast?.('error', 'エラー', 'メールアドレスとパスワードを入力してください。'); return; }

  const { data, error } = await supabase.auth.signInWithPassword({ email, password });
  if (error) { window.showToast?.('error', 'ログインエラー', translateError(error.message)); return; }
  if (data.user) await supabase.from('profiles').update({ last_login_at: new Date().toISOString() }).eq('id', data.user.id);
  window.location.href = '/dashboard';
});

resetButton?.addEventListener('click', async () => {
  const email = window.prompt('再発行先のメールアドレスを入力してください');
  if (!email) return;
  const { error } = await supabase.auth.resetPasswordForEmail(email, { redirectTo: `${window.location.origin}/auth/login` });
  if (error) { window.showToast?.('error', 'エラー', translateError(error.message)); return; }
  window.showToast?.('success', '送信完了', 'パスワード再設定メールを送信しました。');
});
</script>
