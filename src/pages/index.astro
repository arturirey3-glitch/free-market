---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import { createSupabaseServer } from '../lib/supabaseServer';
export const prerender = false;

Astro.response.headers.set('Cache-Control', 'no-store');

let products: any[] = [];
let pickupProducts: any[] = [];
let errorMessage = '';

const buildRatingMap = (rows: { product_id: string; rating: number | null }[]) => {
  const map = new Map<string, { count: number; sum: number }>();
  rows.forEach((row) => {
    if (!row.product_id || row.rating == null) return;
    const c = map.get(row.product_id) ?? { count: 0, sum: 0 };
    c.count += 1;
    c.sum += row.rating;
    map.set(row.product_id, c);
  });
  return map;
};

try {
  const supabase = createSupabaseServer();
  const { data, error } = await supabase
    .from('products')
    .select('id,title,price,category,thumbnail_url,is_pickup,profiles:owner_id(display_name,avatar_url)')
    .eq('status', 'published')
    .order('is_pickup', { ascending: false })
    .order('sort_order', { ascending: true, nullsFirst: false })
    .order('created_at', { ascending: false })
    .limit(60);

  if (error) throw error;
  const all = data ?? [];

  const ids = all.map((p) => p.id).filter(Boolean);
  let ratingMap = new Map<string, { count: number; sum: number }>();
  if (ids.length > 0) {
    const { data: revRows } = await supabase.from('reviews').select('product_id,rating').in('product_id', ids);
    if (revRows) ratingMap = buildRatingMap(revRows);
  }

  const withRatings = all.map((p) => {
    const s = ratingMap.get(p.id);
    return { ...p, review_count: s?.count ?? 0, review_average: s && s.count > 0 ? s.sum / s.count : 0 };
  });

  pickupProducts = withRatings.filter((p) => p.is_pickup);
  products = withRatings.filter((p) => !p.is_pickup);
} catch {
  errorMessage = 'データの取得に失敗しました。';
}
---
<BaseLayout
  title="felikko | スタバ・マリメッコ雑貨のフリマ通販"
  description="felikkoはスタバグッズ・マリメッコ・北欧インテリア雑貨を中心としたフリマ通販サイトです。クッションカバー・マット・スマホリングなど人気商品を多数取り揃え。即購入OK・送料込みで安心お買い物。"
  jsonLd={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "felikko",
    "url": "https://www.felikko.com",
    "description": "スタバ・マリメッコ・北欧インテリア雑貨のフリマ通販サイト",
    "potentialAction": {
      "@type": "SearchAction",
      "target": { "@type": "EntryPoint", "urlTemplate": "https://www.felikko.com/products?q={search_term_string}" },
      "query-input": "required name=search_term_string"
    }
  })}
>
  <div class="mx-auto max-w-[1440px] px-4 py-6">
    <h1 class="sr-only">felikko | スタバ・マリメッコ雑貨のフリマ通販</h1>
    {errorMessage && (
      <div class="mb-4 rounded-lg border border-amber-300 bg-amber-50 px-4 py-3 text-sm text-amber-700">
        {errorMessage}
      </div>
    )}

    {pickupProducts.length > 0 && (
      <section class="mb-8">
        <h2 class="text-base font-bold mb-4 flex items-center gap-1.5">
          <span>⭐</span> ピックアップ商品
        </h2>
        <div class="grid-products">
          {pickupProducts.map((product) => <ProductCard product={product} />)}
        </div>
      </section>
    )}

    <h2 class="text-base font-bold mb-4">新着商品</h2>
    {products.length > 0 ? (
      <div class="grid-products">
        {products.map((product) => <ProductCard product={product} />)}
      </div>
    ) : (
      <p class="text-sm text-[var(--text-secondary)] py-12 text-center">
        まだ商品がありません。<a href="/dashboard/products/new" class="text-[var(--primary)] font-bold">出品する</a>
      </p>
    )}
  </div>
</BaseLayout>
